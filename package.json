{
  "name": "fugue-web",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "apps/examples/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.1",
    "node": ">=20.9.0"
  },
  "scripts": {
    "admin:recover": "bun run --cwd apps/web admin:recover",
    "build": "turbo run build",
    "bundle:check": "bun scripts/quality/bundle-check.mjs",
    "clean": "turbo run clean && rm -rf .turbo",
    "container:check": "node scripts/quality/container-check.mjs",
    "contract:check": "bun run openapi:sync:check && bun run openapi:generate:check && bun run --cwd apps/web typecheck",
    "coss:upstream:diff": "node ./scripts/coss-upstream.mjs diff",
    "coss:upstream:verify": "node ./scripts/coss-upstream.mjs verify",
    "dev": "turbo run dev --filter=@fugue/web",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "i18n:check": "bun scripts/quality/i18n-check.mjs",
    "lint": "turbo run lint",
    "licenses:check": "bun scripts/quality/licenses-sbom.mjs",
    "openapi:generate": "bun run --cwd apps/web openapi:generate",
    "openapi:generate:check": "bun run --cwd apps/web openapi:generate:check",
    "openapi:refresh": "bun run openapi:sync && bun run openapi:generate",
    "openapi:sync": "node ./scripts/sync-fugue-openapi.mjs",
    "openapi:sync:check": "node ./scripts/sync-fugue-openapi.mjs --check",
    "registry:build": "bun run --cwd apps/ui registry:build",
    "registry:sync": "bun run --cwd apps/ui ui:sync",
    "registry:sync:check": "bun run --cwd apps/ui ui:sync:check",
    "registry:validate": "bun run --cwd apps/ui registry:validate-deps",
    "registry:validate-deps": "bun run --cwd apps/ui registry:validate-deps",
    "security:audit": "bun scripts/quality/security-audit.mjs",
    "security:output:gate": "node scripts/quality/secret-output-gate.mjs --",
    "start": "bun run --cwd apps/web start",
    "test": "turbo run test",
    "test:a11y": "bun run --cwd apps/web test:a11y",
    "test:e2e": "bun run --cwd apps/web test:e2e",
    "test:integration": "turbo run test:integration --filter=@fugue/web",
    "test:upload-stress": "bun run --cwd apps/web test:upload-stress",
    "test:style-audit": "bun scripts/quality/style-audit.mjs",
    "test:unit": "turbo run test:unit",
    "theme:check": "bun run --cwd apps/ui theme:check",
    "typecheck": "turbo run typecheck",
    "ui:sync:check": "bun run --cwd apps/ui ui:sync:check",
    "versions:check": "bun scripts/quality/versions-check.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "turbo": "2.10.4",
    "typescript": "7.0.2"
  },
  "overrides": {
    "@redocly/openapi-core": "1.34.17",
    "postcss": "8.5.17"
  },
  "trustedDependencies": [
    "@fugue/ui-registry"
  ],
  "patchedDependencies": {
    "next@16.2.10": "patches/next@16.2.10.patch"
  }
}
