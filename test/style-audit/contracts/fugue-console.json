{
  "schemaVersion": 1,
  "contracts": [
    {
      "id": "tokens.coss-semantic-theme",
      "sourceFile": "packages/ui/src/styles/globals.css",
      "rootSelector": ":root",
      "surfaceOwner": ":root",
      "strictness": "blocker",
      "states": ["default", "reduced-motion", "forced-colors"],
      "requiredSourcePatterns": [
        "--background:",
        "--foreground:",
        "--border:",
        "--ring:",
        "@media (prefers-reduced-motion: reduce)",
        "@media (forced-colors: active)"
      ]
    },
    {
      "id": "control.button",
      "sourceFile": "apps/ui/registry/default/ui/button.tsx",
      "rootSelector": "[data-slot='button']",
      "surfaceOwner": "[data-slot='button']",
      "strictness": "blocker",
      "states": ["default", "hover", "focus-visible", "pressed", "disabled", "loading"],
      "requiredSourcePatterns": [
        "data-slot\": \"button\"",
        "focus-visible:ring-2",
        "disabled:pointer-events-none",
        "data-loading"
      ]
    },
    {
      "id": "control.input-single-surface",
      "sourceFile": "apps/ui/registry/default/ui/input.tsx",
      "rootSelector": "[data-slot='input-control']",
      "surfaceOwner": "[data-slot='input-control']",
      "strictness": "blocker",
      "states": ["default", "focus-visible", "disabled", "error", "long-text"],
      "requiredSourcePatterns": [
        "data-slot=\"input-control\"",
        "data-slot=\"input\"",
        "has-focus-visible:ring-[3px]",
        "has-aria-invalid"
      ]
    },
    {
      "id": "form.field",
      "sourceFile": "apps/ui/registry/default/ui/field.tsx",
      "rootSelector": "[data-slot='field']",
      "surfaceOwner": "[data-slot='input-control']",
      "strictness": "blocker",
      "states": ["default", "disabled", "error", "long-text"],
      "requiredSourcePatterns": [
        "data-slot=\"field\"",
        "data-slot=\"field-group\"",
        "data-slot=\"field-label\"",
        "data-slot=\"field-error\""
      ]
    },
    {
      "id": "modal.dialog",
      "sourceFile": "apps/ui/registry/default/ui/dialog.tsx",
      "rootSelector": "[data-slot='dialog-popup']",
      "surfaceOwner": "[data-slot='dialog-popup']",
      "strictness": "blocker",
      "states": ["default", "focus-visible", "reduced-motion", "long-text"],
      "requiredSourcePatterns": [
        "data-slot=\"dialog-backdrop\"",
        "data-slot=\"dialog-popup\"",
        "data-slot=\"dialog-title\"",
        "aria-label=\"Close\""
      ]
    },
    {
      "id": "navigation.tabs",
      "sourceFile": "apps/ui/registry/default/ui/tabs.tsx",
      "rootSelector": "[data-slot='tabs']",
      "surfaceOwner": "[data-slot='tabs-list']",
      "strictness": "blocker",
      "states": ["default", "focus-visible", "selected", "disabled"],
      "requiredSourcePatterns": [
        "data-slot=\"tabs\"",
        "data-slot=\"tabs-list\"",
        "data-slot=\"tabs-tab\"",
        "data-slot=\"tabs-content\""
      ]
    },
    {
      "id": "data.table",
      "sourceFile": "apps/ui/registry/default/ui/table.tsx",
      "rootSelector": "[data-slot='table']",
      "surfaceOwner": "[data-slot='table-container']",
      "strictness": "blocker",
      "states": ["default", "hover", "empty", "loading", "long-text", "overflow"],
      "requiredSourcePatterns": [
        "data-slot\": \"table-container\"",
        "data-slot=\"table\"",
        "data-slot=\"table-row\"",
        "overflow-x-auto"
      ]
    },
    {
      "id": "feedback.empty",
      "sourceFile": "apps/ui/registry/default/ui/empty.tsx",
      "rootSelector": "[data-slot='empty']",
      "surfaceOwner": "[data-slot='empty']",
      "strictness": "blocker",
      "states": ["empty", "missing-data", "permission-denied"],
      "requiredSourcePatterns": [
        "data-slot=\"empty\"",
        "data-slot=\"empty-title\"",
        "data-slot=\"empty-description\""
      ]
    },
    {
      "id": "feedback.skeleton",
      "sourceFile": "apps/ui/registry/default/ui/skeleton.tsx",
      "rootSelector": "[data-slot='skeleton']",
      "surfaceOwner": "[data-slot='skeleton']",
      "strictness": "blocker",
      "states": ["loading", "reduced-motion"],
      "requiredSourcePatterns": ["data-slot=\"skeleton\"", "animate-skeleton"]
    },
    {
      "id": "navigation.sidebar",
      "sourceFile": "apps/ui/registry/default/ui/sidebar.tsx",
      "rootSelector": "[data-slot='sidebar']",
      "surfaceOwner": "[data-slot='sidebar-container']",
      "strictness": "blocker",
      "states": ["default", "focus-visible", "selected", "disabled", "overflow"],
      "requiredSourcePatterns": [
        "data-slot=\"sidebar\"",
        "data-slot=\"sidebar-container\"",
        "data-slot=\"sidebar-trigger\""
      ]
    }
  ]
}
