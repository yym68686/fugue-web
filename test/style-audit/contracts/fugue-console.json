{
  "contracts": [
    {
      "id": "design.morlane-token-bridge",
      "rootSelector": ":root",
      "surfaceOwner": "design-system/morlane.css"
    },
    {
      "id": "layout.console-shell",
      "rootSelector": ".fp-shell",
      "surfaceOwner": ".fp-main"
    },
    {
      "id": "layout.project-workbench",
      "rootSelector": ".fg-project-workbench",
      "surfaceOwner": ".fg-project-workbench__main"
    },
    {
      "id": "layout.resource-density",
      "rootSelector": ".fp-project-resource-list, .fg-cluster-node-gallery, .fg-console-table-wrap",
      "surfaceOwner": null
    },
    {
      "id": "control.input-single-surface",
      "rootSelector": ".fp-project-search, .fp-project-select, .fg-field-control, .fg-control-group",
      "surfaceOwner": ".fp-project-search, .fp-project-select, .fg-control-group, .fg-route-composer__shell, .fg-billing-top-up-form__entry, .input-with-button"
    },
    {
      "id": "control.locale-theme-morlane",
      "rootSelector": ".language-select, .theme-toggle",
      "surfaceOwner": ".language-select, .theme-toggle"
    },
    {
      "id": "surface.profile-auth",
      "rootSelector": ".fg-profile-auth-workbench",
      "surfaceOwner": ".fg-profile-auth-provider, .fg-profile-auth-capability"
    },
    {
      "id": "surface.docs-density",
      "rootSelector": ".ml-docs-page",
      "surfaceOwner": ".ml-docs-nav, .ml-docs-card, .ml-docs-table-card"
    },
    {
      "id": "state.complete-coverage",
      "rootSelector": ":focus-visible, [aria-disabled='true'], .is-loading, .is-empty, .is-error",
      "surfaceOwner": null
    },
    {
      "id": "legacy.visual-runtime-detached",
      "rootSelector": ".fp-shell",
      "surfaceOwner": "design-system/morlane.css, app/console-components.css"
    }
  ]
}
