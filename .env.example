# Canonical public origin. Production must use the exact HTTPS origin.
APP_BASE_URL=https://app.example.com
APP_PUBLIC_URL=https://app.example.com
NEXT_PUBLIC_APP_BASE_URL=https://app.example.com

# Independent 32+ character secrets. Generate each value separately.
AUTH_SESSION_SECRET=replace-with-an-independent-32-plus-character-secret
AUTH_RATE_LIMIT_SECRET=replace-with-a-different-32-plus-character-secret
WORKSPACE_STORE_SECRET=replace-with-a-different-32-plus-character-secret
WORKSPACE_STORE_KEY_ID=primary
# Optional JSON object used only during key rotation, for example:
# WORKSPACE_STORE_PREVIOUS_KEYS={"previous-key-id":"previous-32-plus-character-secret"}
WORKSPACE_STORE_PREVIOUS_KEYS=

# Optional one-time bootstrap allow-email. Leaving this blank never promotes the first user.
FUGUE_ADMIN_BOOTSTRAP_EMAIL=

AUTH_TRUST_PROXY_HEADERS=false
AUTH_TRUSTED_PROXY_HOPS=1
EMAIL_VERIFICATION_REQUIRED=true

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://app.example.com/api/auth/google/callback
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL="Fugue <no-reply@example.com>"

GITHUB_AUTH_CLIENT_ID=
GITHUB_AUTH_CLIENT_SECRET=
GITHUB_AUTH_REDIRECT_URI=https://app.example.com/api/auth/github/callback
GITHUB_AUTH_SCOPE=read:user user:email
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://app.example.com/api/github/app/install/callback
GITHUB_OAUTH_SCOPE=repo

FUGUE_API_URL=https://api.example.com
FUGUE_BOOTSTRAP_KEY=replace-with-control-plane-key

POSTGRES_USER=fugue_web
POSTGRES_PASSWORD=replace-with-database-password
POSTGRES_DB=fugue_web
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=
