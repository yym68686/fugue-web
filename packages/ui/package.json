{
  "name": "@fugue/ui",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "./src/styles/globals.css"
  ],
  "exports": {
    "./base-ui/*": "./src/base-ui/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./fonts": "./src/fonts/index.ts",
    "./globals.css": "./src/styles/globals.css",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./postcss.config": "./postcss.config.mjs",
    "./shared/*": "./src/shared/*.tsx"
  },
  "scripts": {
    "build": "bun run typecheck",
    "clean": "rm -rf .turbo node_modules tsconfig.tsbuildinfo",
    "format": "biome format --write src components.json package.json tsconfig.json",
    "lint": "biome lint src",
    "test": "bun test test",
    "test:unit": "bun test test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/inter": "5.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "geist": "1.7.2",
    "lucide-react": "1.20.0",
    "react-day-picker": "9.13.0",
    "tailwind-merge": "3.4.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@fugue/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
